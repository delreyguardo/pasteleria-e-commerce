# ============================================================
# Dulce Margarita — Variables de Entorno
# ============================================================
# Copia este archivo como ".env.local" para desarrollo local,
# o configura estas variables en Cloudflare Pages:
#   Dashboard → Tu Proyecto → Settings → Environment Variables
# ============================================================

# Firebase — Obtené estos valores en:
# https://console.firebase.google.com → Tu Proyecto → Configuración del Proyecto → Tus apps
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ⚠️  IMPORTANTE:
# - NUNCA commitees el archivo .env o .env.local con valores reales
# - El prefijo VITE_ es necesario para que Vite exponga la variable al browser
# - Si no configurás estas variables, la app funciona igual con localStorage como demo
